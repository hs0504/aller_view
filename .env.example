# ─────────────────────────────────────────
# AllerView 환경변수 예시 파일
# 이 파일을 복사해서 .env 로 저장한 뒤
# 각 항목에 실제 키값을 입력하세요.
# ─────────────────────────────────────────

# Google Cloud Vision API (메뉴판 OCR 기능)
# https://console.cloud.google.com 에서 발급
GOOGLE_VISION_API_KEY=

# Supabase (인증 및 사용자 데이터 저장)
# https://supabase.com 프로젝트 설정 > API 에서 확인
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_PUBLISHABLE_KEY=
